<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@+id/logo"
        android:layout_width="@dimen/logo_size"
        android:layout_height="@dimen/logo_size"
        android:src="@drawable/ic_logo_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp"/>

    <TextView
        android:id="@+id/txtWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bem-Vindo De Volta"
        android:textSize="40sp"
        android:textColor="#000"
        android:textStyle="bold"
        android:textAlignment="center"
        android:paddingLeft="30dp"
        android:paddingRight="30dp"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/txtWelcome"
        app:layout_constraintBottom_toTopOf="@id/btnStartModal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/padding_clues_background">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/waveBackground"
                android:layout_width="0dp"
                android:layout_height="@dimen/gray_wave_background"
                android:background="@drawable/ic_wave_gray"
                android:paddingTop="80dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/txtCluesTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dicas de uso"
                    android:textColor="@color/LightBlueAD"
                    android:textSize="@dimen/text_view_clue_title_size"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:letterSpacing="0.1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/txtClue1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Seja claro e objetivo com a sua pergunta"
                    android:textColor="#000"
                    android:textSize="@dimen/text_view_clues_size"
                    android:tag="ignoreFontUtils"
                    android:textStyle="bold"
                    android:letterSpacing="0.07"
                    android:lineSpacingMultiplier="2"
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="40dp"
                    app:layout_constraintTop_toBottomOf="@id/txtCluesTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/txtClue2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Siga o passo a passo"
                    android:textColor="#000"
                    android:textSize="@dimen/text_view_clues_size"
                    android:tag="ignoreFontUtils"
                    android:textStyle="bold"
                    android:letterSpacing="0.07"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="40dp"
                    app:layout_constraintTop_toBottomOf="@id/txtClue1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartModal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/padding_clues_background"
        android:layout_marginHorizontal="20dp"
        android:text="Pedir Ajuda"
        android:textAllCaps="false"
        android:textColor="#FFF"
        android:textSize="@dimen/button_text_size"
        android:textStyle="bold"
        app:backgroundTint="@color/LightBlueAD"
        app:layout_constraintHeight_default="percent"
        app:layout_constraintHeight_percent="0.12"
        app:strokeColor="@color/DarkBlueAD"
        app:strokeWidth="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Button.BottomRadius"/>


</androidx.constraintlayout.widget.ConstraintLayout>