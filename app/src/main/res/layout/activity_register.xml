<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:id="@+id/topSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/ic_borda_inferior"
        android:paddingTop="30dp"
        android:paddingBottom="30dp"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_seta_branca"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Botão Voltar"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voltar"
                android:textColor="@android:color/white"
                android:textSize="25sp"
                android:layout_marginStart="20dp"
                android:letterSpacing="0.06"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/labels"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="top|center_horizontal"
        app:layout_constraintTop_toBottomOf="@id/topSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingTop="50dp"
        android:paddingRight="30dp"
        android:paddingLeft="30dp"
        android:paddingBottom="30dp">

        <TextView
            android:id="@+id/txtViewTitleR"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:textAlignment="center"
            android:text="Vamos criar uma conta!"
            android:textSize="35sp"
            android:textColor="#000000"
            android:letterSpacing="0.07"
            android:textStyle="bold"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            >
            <EditText
                android:id="@+id/inputUsername"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edit_text_height"
                android:hint="Digite seu nome"
                android:background="@drawable/gray_edit_text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/DarkGrayEdTxtAD"
                android:inputType="textPersonName"
                android:imeOptions="actionDone"
                app:strokeColor="#000"
                android:padding="15dp"
                android:clipToPadding="false"
                android:letterSpacing="0.01"
                android:textColorHint="@color/DarkGrayEdTxtAD"
                />

            <TextView
                android:id="@+id/txtViewNameR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preencha corretamente!"
                android:textAlignment="textStart"
                android:textColor="@color/RedAD"
                android:textSize="@dimen/txtViewWrongInf"
                android:textStyle="bold"
                android:visibility="invisible"
                />
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            >

            <EditText
                android:id="@+id/inputUserTelR"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edit_text_height"
                android:hint="Digite seu telefone"
                android:background="@drawable/gray_edit_text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/DarkGrayEdTxtAD"
                android:inputType="phone"
                android:imeOptions="actionDone"
                app:strokeColor="#000"
                android:padding="15dp"
                android:maxLength="15"
                android:letterSpacing="0.01"
                android:clipToPadding="false"
                android:textColorHint="@color/DarkGrayEdTxtAD"
                />
            <TextView
                android:id="@+id/txtViewTelR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preencha corretamente!"
                android:textAlignment="textStart"
                android:textColor="@color/RedAD"
                android:textSize="@dimen/txtViewWrongInf"
                android:textStyle="bold"
                android:visibility="invisible"
                />
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <EditText
                android:id="@+id/inputUserPasswordR"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edit_text_height"
                android:hint="Digite sua senha"
                android:background="@drawable/gray_edit_text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/DarkGrayEdTxtAD"
                android:letterSpacing="0.01"
                android:inputType="textPassword"
                android:imeOptions="actionDone"
                app:strokeColor="#000"
                android:padding="15dp"
                android:clipToPadding="false"
                android:textColorHint="@color/DarkGrayEdTxtAD"
                />
            <TextView
                android:id="@+id/txtViewPasswordR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="textStart"
                android:textColor="@color/RedAD"
                android:textSize="@dimen/txtViewWrongInf"
                android:textStyle="bold"
                android:visibility="invisible"
                />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLoginR"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Já tenho uma conta"
        android:textAllCaps="false"
        android:textColor="@color/LightBlueAD"
        android:textSize="25sp"
        android:textStyle="bold"
        app:backgroundTint="@color/white"
        app:cornerRadius="16dp"
        app:strokeColor="@color/LightBlueAD"
        app:strokeWidth="2dp"
        app:rippleColor="@color/LightBlueAD"
        app:layout_constraintBottom_toTopOf="@id/btnContinueR"
        app:layout_constraintHeight_percent="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="10dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinueR"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Continuar"
        android:textAllCaps="false"
        android:textColor="@color/GreenAd"
        android:textSize="25sp"
        android:textStyle="bold"
        app:backgroundTint="@color/white"
        app:cornerRadius="16dp"
        app:strokeColor="@color/GreenAd"
        app:strokeWidth="2dp"
        app:rippleColor="@color/GreenAd"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="30dp"
        />




</androidx.constraintlayout.widget.ConstraintLayout>
