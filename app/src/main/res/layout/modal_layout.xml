<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="false"
    android:background="@drawable/backgroundcolor_modal"
    android:id="@+id/container"
    >


    <View
        android:id="@+id/viewToCloseModal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:animateLayoutChanges="true"
        android:clickable="true"
        android:focusable="true"
        android:id="@+id/constraintLayout"
        app:layout_constraintWidth_percent=".9"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:id="@+id/modalLoading"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:indeterminateTintMode="src_atop"
            android:indeterminateTint="#127BF3"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/modalSubLayout"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/utendobold"
                android:text="Como posso ajudar?"
                android:textSize="30sp"
                android:textColor="@color/black"
                app:layout_constraintBottom_toTopOf="@id/descText"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="30sp"
                />

            <TextView
                android:id="@+id/descText"
                android:layout_width="300sp"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:fontFamily="@font/utendosemibold"
                android:text="Está com alguma dúvida de como usar um aplicativo?"
                android:textAlignment="center"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/titleText"
                app:layout_constraintBottom_toTopOf="@id/lineDecoration"
                android:layout_marginTop="10sp"
                />

            <View
                android:id="@+id/lineDecoration"
                app:layout_constraintWidth_percent=".9"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#127BF3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/descText"
                app:layout_constraintBottom_toTopOf="@id/sugestoesRapidasLayout"
                android:layout_marginTop="30dp"/>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/sugestoesRapidasLayout"
                app:layout_constraintWidth_percent=".9"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/lineDecoration">

                <ProgressBar
                    android:id="@+id/sugestoesRapidasLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:indeterminateTintMode="src_atop"
                    android:indeterminateTint="#127BF3"
                    />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/sugestoesRapidasSubLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="invisible">
                    <TextView
                        android:id="@+id/sugestoesRapidasTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/utendobold"
                        android:text="Sugestões rápidas"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_marginTop="20sp"
                        app:layout_constraintBottom_toTopOf="@id/sugestoesRapidasBtn"/>

                    <android.widget.Button
                        android:id="@+id/sugestoesRapidasBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5sp"
                        android:layout_marginBottom="15sp"
                        android:background="@drawable/sugestoes_rapidas_btn"
                        android:fontFamily="@font/utendobold"
                        android:paddingHorizontal="20sp"
                        android:paddingBottom="15sp"
                        android:text="Quero pedir uber"
                        android:textSize="16sp"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:layout_constraintBottom_toTopOf="@id/sugestoesRapidasBtn2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/sugestoesRapidasTitle" />
                    <android.widget.Button
                        android:id="@+id/sugestoesRapidasBtn2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15sp"
                        android:background="@drawable/sugestoes_rapidas_btn_inverted"
                        android:fontFamily="@font/utendobold"
                        android:paddingHorizontal="20sp"
                        android:paddingBottom="15sp"
                        android:text="Quero pedir comida"
                        android:textSize="16sp"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:layout_constraintBottom_toTopOf="@id/sugestoesRapidasBtn3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/sugestoesRapidasBtn" />
                    <android.widget.Button
                        android:id="@+id/sugestoesRapidasBtn3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="30sp"
                        android:background="@drawable/sugestoes_rapidas_btn"
                        android:fontFamily="@font/utendobold"
                        android:paddingHorizontal="20sp"
                        android:paddingBottom="15sp"
                        android:text="Quero mandar mensagem"
                        android:textSize="16sp"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/sugestoesRapidasBtn2" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/promptInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintWidth_percent=".9"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sugestoesRapidasLayout"
                app:layout_goneMarginTop="20sp"
                android:layout_marginBottom="50sp">

                <EditText
                    android:id="@+id/promptInput"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="60sp"
                    android:autofillHints="Campo de texto para o prompt"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:background="@drawable/prompt_input_background"
                    android:hint="Escreva aqui"
                    android:paddingStart="15sp"
                    android:paddingEnd="60sp"
                    android:paddingVertical="10sp"
                    android:textColor="#127BF3"
                    android:textColorHint="#509BF2"
                    android:fontFamily="@font/utendosemibold"
                    android:maxLines="7"
                    />

                <ImageButton
                    android:id="@+id/sendPromptBtn"
                    android:layout_width="40sp"
                    android:layout_height="wrap_content"
                    android:contentDescription="Enviar pergunta"
                    android:src="@drawable/sendbtn"
                    android:background="@android:color/transparent"
                    android:scaleType="fitXY"
                    android:adjustViewBounds="true"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginRight="20dp" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageButton
        android:id="@+id/voicePromptInput"
        android:layout_width="85sp"
        android:layout_height="85sp"
        android:adjustViewBounds="false"
        android:background="@drawable/mic_background"
        android:scaleType="centerInside"
        android:src="@drawable/micbtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/constraintLayout"
        android:layout_marginTop="-45sp"
        android:padding="26sp"

        />

</androidx.constraintlayout.widget.ConstraintLayout>
