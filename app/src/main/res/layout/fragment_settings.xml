<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/textTitleSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="30dp"
                android:text="Configurações do aplicativo"
                android:textSize="35sp"
                android:textColor="#000"
                android:textStyle="bold"
                android:textAlignment="center"
                android:letterSpacing="0.1"
                android:layout_marginTop="60dp"/>

            <LinearLayout
                android:padding="30dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tamanho da fonte"
                    android:textSize="25sp"
                    android:textColor="@color/LightGrayAd"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/spinnerConfig"
                    android:layout_width="217dp"
                    android:layout_height="71dp"
                    android:layout_marginTop="20dp"
                    android:entries="@array/config_options"
                    android:spinnerMode="dropdown"
                    android:background="@drawable/spinner_bg"
                    android:popupBackground="@color/DarkGrayAD" />

                <LinearLayout
                    android:layout_marginTop="40dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/textVoice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sistema responder por voz"
                        android:letterSpacing="0.07"
                        android:textColor="@color/LightGrayAd"
                        android:textStyle="bold"
                        android:textSize="23sp"
                        android:singleLine="false"
                        android:textAlignment="center"
                        />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchOptResponseVoice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="#FFF"
                        app:trackTint="@color/track_tint"
                        android:scaleX="1.5"
                        android:scaleY="1.5"
                        android:layout_marginStart="16dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/logOffBtn"
                    android:layout_marginTop="40dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sair da conta"
                    android:textAllCaps="false"
                    android:textColor="#F00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:backgroundTint="#FFF"
                    android:gravity="center" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
